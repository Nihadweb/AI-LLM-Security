# ---- Vulnerable chatbot target (server.py) ----
# DEFAULT backend is Ollama tinyllama (offline, no key). These vars are optional.
# server.py reads real environment variables; the easy way is 2-run-vuln-chatbot.bat.

# Ollama (default):
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama

# FAST mode (optional): set a free Groq key to switch to Groq automatically.
# Get one at https://console.groq.com/keys
# GROQ_API_KEY=gsk_xxx
# OPENAI_MODEL=llama-3.1-8b-instant

# Shorter replies = faster scans
MAX_TOKENS=80

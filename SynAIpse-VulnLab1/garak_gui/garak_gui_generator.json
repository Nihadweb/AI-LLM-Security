{
  "rest": {
    "RestGenerator": {
      "name": "Team5 Bank AI Chatbot",
      "uri": "http://127.0.0.1:5000/chat",
      "method": "post",
      "headers": {
        "Content-Type": "application/json"
      },
      "req_template_json_object": {
        "message": "$INPUT"
      },
      "response_json": true,
      "response_json_field": "reply",
      "request_timeout": 120
    }
  }
}